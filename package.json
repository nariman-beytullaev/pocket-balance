{
  "name": "vibecoding-template",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "webapp",
    "website",
    "mobile",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' --parallel dev",
    "dev:webapp": "bun run --cwd webapp dev",
    "dev:website": "bun run --cwd website dev",
    "dev:mobile": "bun run --cwd mobile dev",
    "dev:backend": "bun run --cwd backend dev",
    "build": "bun run --filter '*' --sequential build",
    "build:webapp": "bun run --cwd webapp build",
    "build:website": "bun run --cwd website build",
    "build:mobile": "bun run --cwd mobile build",
    "build:backend": "bun run --cwd backend build",
    "deploy:do:specs": "bun scripts/prepare-do-specs.mjs",
    "typecheck": "bun run --filter '*' --sequential typecheck",
    "typecheck:webapp": "bun run --cwd webapp typecheck",
    "typecheck:website": "bun run --cwd website typecheck",
    "typecheck:mobile": "bun run --cwd mobile typecheck",
    "typecheck:backend": "bun run --cwd backend typecheck",
    "test": "bun run test:deploy && bun run test:contracts && bun run test:backend && bun run test:webapp && bun run test:mobile",
    "test:deploy": "bun test scripts/do-cron.test.mjs scripts/prepare-do-specs.test.mjs",
    "test:contracts": "bun run --cwd packages/contracts test",
    "test:backend": "bun run --cwd backend test",
    "test:backend:unit": "bun run --cwd backend test:unit",
    "test:backend:integration": "bun run --cwd backend test:integration",
    "test:webapp": "bun run --cwd webapp test",
    "test:mobile": "bun run --cwd mobile test",
    "smoke:backend:docker": "bun run --cwd backend smoke:docker",
    "e2e:webapp": "bun run --cwd webapp e2e",
    "e2e:mobile": "bun run --cwd mobile e2e:maestro"
  }
}
