# Local PostgreSQL from ../docker-compose.yml.
# Keep an explicit username and password in Prisma URLs even on local machines.
# Peer-auth style URLs without a user can produce opaque Prisma schema-engine errors.
DATABASE_URL="postgresql://superuser:superpassword@localhost:54329/web_app_demo?schema=public"

# Test PostgreSQL from ../docker-compose.yml. Backend integration, Docker smoke,
# and Playwright E2E use this shape and must target the *_test database.
TEST_DATABASE_URL="postgresql://superuser:superpassword@localhost:54330/web_app_demo_test?schema=public"

JWT_SECRET="replace-with-at-least-32-random-characters"
CORS_ORIGINS="http://localhost:5173,http://localhost:8081,http://localhost:19006"
ACCESS_TOKEN_TTL_SECONDS="900"
REFRESH_TOKEN_TTL_DAYS="30"
COOKIE_SECURE="false"

# Optional mobile social auth. These are provider identifiers, not secrets.
# APPLE_AUTH_BUNDLE_ID must match mobile ios.bundleIdentifier.
# GOOGLE_AUTH_CLIENT_IDS is a comma-separated allowlist containing every Google
# OAuth client ID whose ID tokens this backend should accept.
APPLE_AUTH_BUNDLE_ID=""
APPLE_AUTH_JWKS_TIMEOUT_MS="5000"
GOOGLE_AUTH_CLIENT_IDS=""

# Optional DigitalOcean Spaces storage. Leave blank until the product needs
# uploads, media, or other persistent files.
SPACES_REGION=""
SPACES_BUCKET=""
SPACES_ENDPOINT=""
SPACES_CDN_BASE_URL=""
SPACES_ACCESS_KEY_ID=""
SPACES_SECRET_ACCESS_KEY=""
SPACES_UPLOAD_MAX_BYTES="10485760"
SPACES_UPLOAD_URL_TTL_SECONDS="900"
SPACES_DOWNLOAD_URL_TTL_SECONDS="300"
SPACES_PUBLIC_CACHE_CONTROL="public, max-age=31536000, immutable"

# Optional iOS App Store subscription verification. Leave credentials blank until
# App Store Connect products, API credentials, and Apple root certificates are
# ready. When credentials are set, APPLE_IAP_PRODUCT_IDS must list every product
# allowed to unlock premium access.
APPLE_IAP_BUNDLE_ID=""
APPLE_IAP_APP_APPLE_ID=""
APPLE_IAP_ENVIRONMENT="Sandbox"
APPLE_IAP_ISSUER_ID=""
APPLE_IAP_KEY_ID=""
APPLE_IAP_PRIVATE_KEY_BASE64=""
APPLE_IAP_ROOT_CERTS_DIR=""
APPLE_IAP_PRODUCT_IDS="com.example.app.premium.monthly,com.example.app.premium.yearly"

# Optional Expo Push access token. Leave blank unless the Expo project enables
# push security. APNs/FCM credentials are configured in Expo/EAS, not here.
EXPO_PUSH_ACCESS_TOKEN=""
PUSH_OUTBOX_PROCESS_LIMIT=""
PUSH_OUTBOX_PROCESS_MAX_LOOPS=""
PUSH_OUTBOX_PROCESS_MAX_RUNTIME_MS=""
PUSH_OUTBOX_PROCESSING_STALE_MS=""
PUSH_RECEIPT_CHECK_LIMIT=""
